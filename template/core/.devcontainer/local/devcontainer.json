{
  "name": "tpl (local Dockerfile)",
  "build": {
    "dockerfile": "../../Dockerfile",
    "target": "dev",
    "args": {
      "LLVM_VERSION": "21",
      "GCC_VERSION": "14"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "DavidAnson.vscode-markdownlint",
        "eamodio.gitlens",
        "github.vscode-github-actions",
        "redhat.vscode-yaml",
        "tboox.xmake-vscode",
        "vadimcn.vscode-lldb"
      ]
    }
  }
}